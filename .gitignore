# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Editable installs
src/*.egg-info/

# External workspace folders (Windows symlinks to sibling repos)
.external/
external/
.scratchpad/

# Editor / IDE
.vscode/
.vs/
.idea/

# Per-machine Claude Code state
.claude/settings.json
.claude/settings.local.json

# Python virtual environments
.venv
.venv*
env/
venv/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

# Type-checker caches
.mypy_cache/
.ruff_cache/
.pytype/

# Docs build
docs/_build/
docs/site/
site/

# Experiment side-effects: .err captures and one-off scratch.
# .log files are tracked (allow-rule below) so PASS/FAIL runs are
# part of the project history.
data/*.err
*.log
!data/*.log

# Stage / promote outputs (per-version snapshots if used)
stage/
.stage/

# OS junk
.DS_Store
Thumbs.db
